global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect 5000ms
    timeout client  50000ms
    timeout server  50000ms

frontend kubernetes
    bind {{ ansible_host }}:{{ haproxy.frontend_port }}
    option tcplog
    mode tcp
    default_backend kubernetes-controlplane-nodes

backend kubernetes-controlplane-nodes
    mode tcp
    balance {{ haproxy.balance }}
    option tcp-check
{% for host in groups[haproxy.backend_group] %}
    server {{ host.split('.')[0] }} {{ hostvars[host].ansible_host }}:{{ haproxy.backend_port }} check fall {{ haproxy.fall }} rise {{ haproxy.rise }}
{% endfor %}

listen stats
    bind *:{{ haproxy.stats_port }}
    mode http
    stats enable
    stats uri {{ haproxy.stats_uri }}
    stats refresh {{ haproxy.stats_refresh }}
